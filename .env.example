# ════════════════════════════════════════════════════════════════
# ProgectLibrary - Environment Configuration Template
# ════════════════════════════════════════════════════════════════
# 
# INSTRUCTIONS:
# 1. Copy this file to .env (same directory)
# 2. Generate keys using: python scripts/generate_keys.py
# 3. Update values as needed for your environment
# 4. NEVER commit .env to git (it's in .gitignore)
#
# ════════════════════════════════════════════════════════════════
# CRITICAL: Must be configured before first run
# ════════════════════════════════════════════════════════════════

# JWT Secret for signing access/refresh tokens (min 32 random characters)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-min-32-chars-long-please

# Fernet encryption key for data files (generated from script)
# Generate: python scripts/generate_keys.py
FERNET_KEY=

# HMAC key for signing audit log entries (generated from script)
# Generate: python scripts/generate_keys.py
AUDIT_HMAC_KEY=

# Application Environment (development or production)
APP_ENV=development

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ════════════════════════════════════════════════════════════════
# OPTIONAL: Notifications (leave blank for development/testing)
# ════════════════════════════════════════════════════════════════

# SMS Notifications via Twilio
# Get credentials: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email Notifications via SMTP
# Example for Gmail (requires app-specific password)
# See: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ════════════════════════════════════════════════════════════════
# OPTIONAL: Storage Configuration (defaults should work fine)
# ════════════════════════════════════════════════════════════════

# Directory for encrypted data files
DATA_DIR=./data